<?xml version="1.0" encoding="UTF-8"?>

<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         version="3.1">

    <!-- LOGIN -->
    <servlet>
        <servlet-name>Login</servlet-name>
        <servlet-class>tracker.LoginServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>

    <!-- REGISTER -->
    <servlet>
        <servlet-name>Register</servlet-name>
        <servlet-class>tracker.RegisterServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Register</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <!-- DASHBOARD -->
    <servlet>
        <servlet-name>Dashboard</servlet-name>
        <servlet-class>tracker.DashboardServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Dashboard</servlet-name>
        <url-pattern>/dashboard</url-pattern>
    </servlet-mapping>

    <!-- ADD EXPENSE -->
    <servlet>
        <servlet-name>Add</servlet-name>
        <servlet-class>tracker.AddExpenseServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Add</servlet-name>
        <url-pattern>/add</url-pattern>
    </servlet-mapping>

    <!-- VIEW EXPENSE -->
    <servlet>
        <servlet-name>View</servlet-name>
        <servlet-class>tracker.ViewExpenseServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>View</servlet-name>
        <url-pattern>/view</url-pattern>
    </servlet-mapping>

    <!-- DELETE -->
    <servlet>
        <servlet-name>Delete</servlet-name>
        <servlet-class>tracker.DeleteExpenseServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Delete</servlet-name>
        <url-pattern>/delete</url-pattern>
    </servlet-mapping>

    <!-- EDIT -->
    <servlet>
        <servlet-name>Edit</servlet-name>
        <servlet-class>tracker.EditExpenseServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Edit</servlet-name>
        <url-pattern>/edit</url-pattern>
    </servlet-mapping>

    <!-- UPDATE -->
    <servlet>
        <servlet-name>Update</servlet-name>
        <servlet-class>tracker.UpdateExpenseServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Update</servlet-name>
        <url-pattern>/update</url-pattern>
    </servlet-mapping>

    <!-- LOGOUT -->
    <servlet>
        <servlet-name>Logout</servlet-name>
        <servlet-class>tracker.LogoutServlet01</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>Logout</servlet-name>
        <url-pattern>/logout</url-pattern>
    </servlet-mapping>

    <!-- DEFAULT PAGE -->
    <welcome-file-list>
        <welcome-file>login.html</welcome-file>
    </welcome-file-list>

</web-app>